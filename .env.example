
# --- LLM ---
ANTHROPIC_API_KEY=
# Vision-capable Claude model used for extraction + forgery heuristics + summary.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Database ---
# Default points at the Postgres container in docker-compose.yml.
# To run without Docker, switch to: sqlite:///./iasw.db
DATABASE_URL=postgresql+psycopg2://iasw:iasw@localhost:55432/iasw
# --- Storage (mock FileNet) ---
FILENET_ROOT=./filenet_storage

# --- API / UI ---
API_HOST=0.0.0.0
API_PORT=8000
# Streamlit reads this to know where the FastAPI backend is.
API_BASE_URL=http://localhost:8000

# --- Confidence thresholds (tunable; used by Summary Agent for recommendation) ---
# Overall confidence above this -> recommend APPROVE; below APPROVE_THRESHOLD but above REJECT_THRESHOLD -> recommend REVIEW.
APPROVE_THRESHOLD=0.85
REJECT_THRESHOLD=0.50

# --- Logging ---
LOG_LEVEL=INFO
